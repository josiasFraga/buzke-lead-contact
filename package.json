{
  "name": "buzke-lead-contact",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "start": "node dist/index.js",
    "evolution:help": "powershell -ExecutionPolicy Bypass -File ./scripts/evolution-local.ps1 help",
    "evolution:env:init": "powershell -ExecutionPolicy Bypass -File ./scripts/init-evolution-local.ps1",
    "evolution:up": "powershell -ExecutionPolicy Bypass -File ./scripts/evolution-local.ps1 up",
    "evolution:down": "powershell -ExecutionPolicy Bypass -File ./scripts/evolution-local.ps1 down",
    "evolution:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/evolution-local.ps1 reset",
    "evolution:logs": "powershell -ExecutionPolicy Bypass -File ./scripts/evolution-local.ps1 logs"
  },
  "dependencies": {
    "@google/genai": "^1.8.0",
    "axios": "^1.9.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "form-data": "^4.0.2",
    "mime-types": "^3.0.1",
    "mysql2": "^3.14.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/form-data": "^2.5.2",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.13.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}